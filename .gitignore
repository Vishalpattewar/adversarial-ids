# ─────────────────────────────────────────────
# .gitignore
# Excludes large data files, trained models,
# generated results and virtual environment.
# Anyone cloning this repo must:
#   1. pip install -r requirements.txt
#   2. Download NSL-KDD dataset manually
#   3. Run prepare_kdd.py
#   4. Run run_experiment.py
# ─────────────────────────────────────────────

# Dataset files — too large for GitHub (125MB+)
data/

# Trained model weights — regenerated by run_experiment.py
models/

# Generated results — regenerated by run_experiment.py
results/

# Python virtual environment
venv/

# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# VSCode settings
.vscode/

# OS files
.DS_Store
Thumbs.db